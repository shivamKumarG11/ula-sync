# =============================================================================
# Traveloop Frontend — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Never put secrets (keys with write access, private keys) here.
# The app degrades gracefully — missing optional keys disable specific UI
# features but will NOT crash the application.
# =============================================================================


# -----------------------------------------------------------------------------
# BACKEND API URL                                                    [REQUIRED]
# -----------------------------------------------------------------------------
# What it is:  The base URL of the Traveloop Flask backend server.
#
# How to set:
#   - Local dev:   http://localhost:5000  (default — matches run.py)
#   - Production:  https://api.yourdomain.com
#
# Impact if missing:
#   CRITICAL — the entire app stops working. Login, trips, cities,
#   community posts — all data fetching returns network errors.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000


# -----------------------------------------------------------------------------
# MAPBOX PUBLIC TOKEN                                                [OPTIONAL]
# -----------------------------------------------------------------------------
# What it is:  A browser-safe public access token for Mapbox GL JS.
#              Used to render interactive maps on itinerary and city pages.
#
# How to get (free, takes 2 minutes):
#   1. Visit https://account.mapbox.com/  → create a free account
#   2. On the dashboard you'll see a "Default public token" — copy it
#      (starts with "pk.eyJ1...")
#   3. Paste it below
#
# Security:   Public tokens are read-only and safe in browser code.
#             You can further restrict them by URL in the Mapbox dashboard.
#
# Free tier:  50,000 map loads/month — more than enough for development
#             and small-scale production use.
#
# Impact if missing or invalid:
#   LOW — maps won't render (blank grey canvas on map pages).
#   All other features (trips, AI, community, packing) work normally.
#   Map components auto-hide when the token is absent.
#
# Docs: https://docs.mapbox.com/help/getting-started/access-tokens/
# -----------------------------------------------------------------------------
VITE_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbHh4eHh4eHgifQ.xxxxxxxxxxxxxxxxxxxxxxxx
