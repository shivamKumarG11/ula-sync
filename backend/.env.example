# =============================================================================
# Traveloop Backend — Environment Variables
# =============================================================================
# Copy this file to `.env` in the backend/ directory:
#   cp .env.example .env
#
# Then fill in every [REQUIRED] value before running the server.
# [OPTIONAL] keys enable specific features but the app works without them.
# =============================================================================


# =============================================================================
# CORE APPLICATION SETTINGS                                         [REQUIRED]
# =============================================================================

# Flask runtime environment.
# Options: development | production | testing
# In production set to "production" — disables debug mode and detailed errors.
FLASK_ENV=development

# Secret key used for Flask session signing and CSRF tokens.
# How to generate a strong key (run in terminal):
#   python -c "import secrets; print(secrets.token_hex(32))"
# Impact if weak/default: sessions can be forged — SECURITY RISK in production.
SECRET_KEY=change-me-to-a-long-random-string-use-secrets.token_hex(32)

# -----------------------------------------------------------------------------
# POSTGRESQL DATABASE                                                [REQUIRED]
# -----------------------------------------------------------------------------
# What it is:  SQLAlchemy connection string to your PostgreSQL database.
# Format:  postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# Local setup (first time):
#   1. Install PostgreSQL: https://www.postgresql.org/download/
#   2. Run: createdb traveloop
#   3. Create user: psql -c "CREATE USER traveloop WITH PASSWORD 'traveloop';"
#   4. Grant access: psql -c "GRANT ALL ON DATABASE traveloop TO traveloop;"
#
# Then run migrations: cd backend && flask db upgrade
# Then seed data:      python scripts/seed.py
#
# Impact if wrong: The server will crash on startup with a database error.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://traveloop:traveloop@localhost:5432/traveloop


# =============================================================================
# JWT AUTHENTICATION                                                 [REQUIRED]
# =============================================================================

# Secret key used to sign JWT access and refresh tokens.
# Must be DIFFERENT from SECRET_KEY above.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Impact if changed in production: all existing sessions will be invalidated.
JWT_SECRET_KEY=change-me-to-another-long-random-string

# How long access tokens are valid (in seconds).
# 900 = 15 minutes. Shorter = more secure, requires more refresh calls.
JWT_ACCESS_TOKEN_EXPIRES=900

# How long refresh tokens are valid (in seconds).
# 604800 = 7 days. Users are logged out after this period of inactivity.
JWT_REFRESH_TOKEN_EXPIRES=604800


# =============================================================================
# CORS & FILE UPLOADS                                                [REQUIRED]
# =============================================================================

# Comma-separated list of allowed frontend origins.
# Must exactly match the URL your frontend runs on (no trailing slash).
# Local dev: http://localhost:5173 (Vite default port)
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Directory where user-uploaded files (avatars, covers) are stored.
# Relative to backend/ directory. Created automatically on first upload.
UPLOAD_FOLDER=./uploads

# Maximum upload file size in bytes.
# 5242880 = 5 MB. Increase if users need to upload larger images.
MAX_CONTENT_LENGTH=5242880


# =============================================================================
# AI — TOKEN ROUTER                                                  [OPTIONAL]
# =============================================================================
# What it is:  Token Router is an OpenAI-compatible API gateway that routes
#              requests to various LLMs (GPT-4, Claude, Gemini, etc.) with
#              automatic fallback and cost optimization.
#
# Powers these app features:
#   - AI itinerary generation (day-by-day plans)
#   - Activity suggestions for each city stop
#   - Transport recommendations between cities
#   - Trip review and feedback (strengths, improvements)
#   - Packing list suggestions based on destinations
#   - AI travel chatbot (floating assistant)
#
# How to get a key:
#   1. Visit https://tokenrouter.com  → Sign up
#   2. Go to API Keys → Create new key
#   3. Paste it below
#
# Alternative: If you have an OpenAI API key, you can often use that directly
#   by pointing TOKEN_ROUTER_BASE_URL to https://api.openai.com/v1
#   and using your OpenAI key as TOKEN_ROUTER_API_KEY.
#
# Impact if missing:
#   MEDIUM — all AI features show a friendly fallback message:
#   "AI itinerary generation is temporarily unavailable. You can still
#    build your itinerary manually using the activity catalog."
#   The app remains fully usable for manual trip planning.
# =============================================================================
TOKEN_ROUTER_API_KEY=your_token_router_api_key_here
TOKEN_ROUTER_BASE_URL=https://api.tokenrouter.com/v1


# =============================================================================
# AMADEUS FLIGHTS & HOTELS API                                       [OPTIONAL]
# =============================================================================
# What it is:  Amadeus for Developers — real-time flight search, hotel
#              availability, and airport information.
#
# Powers: Transport recommendation feature (real flight price data)
#
# How to get a key (free sandbox, takes 5 minutes):
#   1. Visit https://developers.amadeus.com/
#   2. Sign up → "My Self-Service Workspace" → Create new app
#   3. Copy API Key and API Secret
#   4. Start with the SANDBOX (test) URL — no real money involved
#   5. Upgrade to production when ready: change AMADEUS_BASE_URL below
#
# Sandbox vs Production:
#   Sandbox:    https://test.api.amadeus.com   (fake data, free, unlimited)
#   Production: https://api.amadeus.com        (real data, pay-per-call)
#
# Impact if missing:
#   LOW — transport recommendations still work using AI text suggestions
#   (no real-time pricing). The AI fallback gives generic guidance like
#   "fly from City A to City B, estimated $200-400".
# =============================================================================
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here
AMADEUS_BASE_URL=https://test.api.amadeus.com


# =============================================================================
# OPENTRIPMAP API                                                    [OPTIONAL]
# =============================================================================
# What it is:  OpenTripMap provides POI (points of interest) data for 600,000+
#              locations worldwide — museums, landmarks, restaurants, etc.
#
# Powers: Activity catalog enrichment and city POI data
#
# How to get a key (free tier available):
#   1. Visit https://opentripmap.io/product
#   2. Sign up → go to dashboard → copy your API key
#   Free tier: 1,000 requests/day
#
# Impact if missing:
#   LOW — the seeded city activity data from the data/ folder is still used.
#   New city discovery and POI enrichment are disabled.
# =============================================================================
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here


# =============================================================================
# UNSPLASH API                                                       [OPTIONAL]
# =============================================================================
# What it is:  Unsplash provides high-quality free travel photos via API.
#              Used to auto-populate city and trip cover photos.
#
# Powers: Auto-filling cover photos for newly added cities
#
# How to get a key (free, instant):
#   1. Visit https://unsplash.com/developers
#   2. "Your apps" → "New Application" → accept terms
#   3. Copy "Access Key" (not Secret Key — that's for write operations)
#   Free tier: 50 requests/hour
#
# Impact if missing:
#   LOW — manually uploaded photos still work. Auto-populated city covers
#   from the data/ folder (bali.jpg, santorini.jpg, etc.) are used instead.
# =============================================================================
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here


# =============================================================================
# TICKETMASTER API                                                   [OPTIONAL]
# =============================================================================
# What it is:  Ticketmaster Discovery API for real events, concerts, sports,
#              and shows at travel destinations.
#
# Powers: "Events near your stop" feature in activity suggestions
#
# How to get a key (free, instant approval):
#   1. Visit https://developer.ticketmaster.com/
#   2. Sign in → My Apps → Add a New App → copy Consumer Key
#   Free tier: 5,000 API calls/day
#
# Impact if missing:
#   LOW — the events section is hidden. All other activity features work.
# =============================================================================
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here


# =============================================================================
# YELP FUSION API                                                    [OPTIONAL]
# =============================================================================
# What it is:  Yelp Fusion API for restaurant search, ratings, and reviews
#              at travel destinations.
#
# Powers: Restaurant recommendations within activity suggestions
#
# How to get a key (free):
#   1. Visit https://www.yelp.com/developers/
#   2. "Create App" → fill in details → copy API Key
#   Free tier: 500 calls/day
#
# Impact if missing:
#   LOW — restaurant recommendations fall back to OpenTripMap data.
#   Food activities in the seeded city data are always available.
# =============================================================================
YELP_API_KEY=your_yelp_fusion_api_key_here


# =============================================================================
# AVIATIONSTACK API                                                  [OPTIONAL]
# =============================================================================
# What it is:  Real-time flight status, airline routes, and airport data.
#              Used for enriching transport recommendations with live data.
#
# Powers: Live flight status and route availability checks
#
# How to get a key (free tier available):
#   1. Visit https://aviationstack.com/
#   2. "Get Free API Key" → sign up → copy your key from dashboard
#   Free tier: 100 requests/month (enough for development/demos)
#
# Impact if missing:
#   LOW — transport recommendations work via AI text suggestions.
#   Real-time flight status is simply not shown.
# =============================================================================
AVIATIONSTACK_KEY=your_aviationstack_api_key_here
