OPENTRIPMAP_API_KEY=your_key_here
UNSPLASH_ACCESS_KEY=your_key_here
TICKETMASTER_API_KEY=your_key_here
YELP_API_KEY=your_key_here
AVIATIONSTACK_KEY=your_key_here

# AI
TOKEN_ROUTER_API_KEY=your_key_here
